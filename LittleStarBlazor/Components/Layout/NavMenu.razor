@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject IJSRuntime JSRuntime

<header class="header @(isScrolled ? "scrolled" : "")" id="header">
    <nav class="nav container">
        <a href="" class="nav__logo" @onclick="CloseMenu">
            <img src="assets/images/logo.png" alt="Little Star Nursery Logo" class="nav__logo-img" />
        </a>

        <ul class="nav__menu @(isMenuOpen ? "open" : "")" id="navMenu">
            <li><NavLink href="" Match="NavLinkMatch.All" class="nav__link" @onclick="CloseMenu">Home</NavLink></li>
            <li><NavLink href="about" class="nav__link" @onclick="CloseMenu">About Us</NavLink></li>
            <li><NavLink href="programs" class="nav__link" @onclick="CloseMenu">Programs</NavLink></li>
            <li><NavLink href="gallery" class="nav__link" @onclick="CloseMenu">Gallery</NavLink></li>
            <li><NavLink href="branches" class="nav__link" @onclick="CloseMenu">Branches</NavLink></li>
            <li><NavLink href="contact" class="nav__link" @onclick="CloseMenu">Contact</NavLink></li>
            <li>
                <a href="tel:+919099520954" class="nav__phone">
                    <i class="fas fa-phone-alt"></i> +91 90995 20954
                </a>
            </li>
            <li><NavLink href="/#contact" class="btn btn--primary nav__cta" @onclick="CloseMenu"><i class="fas fa-star"></i> Enroll Now</NavLink></li>
        </ul>

        <button class="nav__hamburger @(isMenuOpen ? "open" : "")" 
                id="hamburger" 
                aria-label="Toggle menu" 
                aria-expanded="@isMenuOpen.ToString().ToLower()"
                @onclick="ToggleMenu">
            <span></span><span></span><span></span>
        </button>
    </nav>
</header>

@code {
    private bool isMenuOpen = false;
    private bool isScrolled = false;
    private DotNetObjectReference<NavMenu>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerScrollListener", objRef);
        }
    }

    [JSInvokable]
    public void OnScroll(double scrollY)
    {
        var shouldBeScrolled = scrollY > 20;
        if (isScrolled != shouldBeScrolled)
        {
            isScrolled = shouldBeScrolled;
            StateHasChanged();
        }
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}
