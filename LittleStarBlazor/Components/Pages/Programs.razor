@page "/programs"
@inject LittleStarBlazor.Services.ContentService ContentService

<PageTitle>Our Programs | Little Star Nursery – Holistic Early Learning</PageTitle>

<!-- ========== PROGRAMS HERO ========== -->
<section class="hero hero--sub" id="programs-hero">
    <div class="hero__circle hc-2"></div>
    <div class="hero__circle hc-4"></div>
    
    <div class="container">
        <div class="hero__content text-center" style="max-width: 800px; margin: 0 auto;" data-aos="fade-up">
            <div class="hero__badge-top">
                <i class="fas fa-book-open"></i> Academic Excellence
            </div>
            <h1 class="hero__heading">
                Learning Through <br>
                <span class="ht-green">Play</span> & <span class="ht-yellow">Discovery</span>
            </h1>
            <p class="hero__sub">
                Our curriculum is carefully crafted to nurture curiosity, build confidence, and foster a lifelong love for learning in every child.
            </p>
        </div>
    </div>

    <div class="hero__wave">
        <svg viewBox="0 0 1440 110" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 60C240 110 480 20 720 60C960 100 1200 20 1440 60V110H0V60Z" fill="#ffffff" />
        </svg>
    </div>
</section>

<!-- ========== PROGRAM HIGHLIGHTS ========== -->
<section class="programs-highlight section">
    <div class="container">
        @{
            var programs = ContentService.GetPrograms();
            for (int i = 0; i < programs.Count; i++)
            {
                var program = programs[i];
                var isEven = i % 2 == 0;
                
                <div class="program-row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 60px; align-items: center; margin-bottom: 100px;">
                    <div class="program-visual @(isEven ? "" : "order-md-2")" data-aos="@(isEven ? "fade-right" : "fade-left")">
                        <div class="p-img-wrap" style="position: relative;">
                            <img src="@program.ImagePath" alt="@program.Title" style="width: 100%; border-radius: 30px; box-shadow: var(--shadow-lg);" />
                            <div class="p-badge" style="position: absolute; top: -20px; right: -20px; background: var(--white); padding: 15px 25px; border-radius: 20px; box-shadow: var(--shadow-md); text-align: center;">
                                <span style="display: block; font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Age Group</span>
                                <strong style="font-size: 1.2rem; color: var(--primary);">@program.AgeRange</strong>
                            </div>
                        </div>
                    </div>
                    
                    <div class="program-content @(isEven ? "" : "order-md-1")" data-aos="@(isEven ? "fade-left" : "fade-right")">
                        <span class="sec-badge" style="background: var(--lavender); color: var(--purple);"><i class="@program.IconClass"></i> @program.Duration</span>
                        <h2 class="sec-heading">@program.Title</h2>
                        <div class="sh-underline"></div>
                        <p class="about-text" style="font-size: 1.1rem;">@program.Description</p>
                        
                        <ul class="curriculum-list" style="margin-top: 24px; display: grid; gap: 12px;">
                            <li><i class="fas fa-check-circle" style="color: var(--green);"></i> Sensory & Motor Skill Development</li>
                            <li><i class="fas fa-check-circle" style="color: var(--green);"></i> Interactive Storytelling & Rhymes</li>
                            <li><i class="fas fa-check-circle" style="color: var(--green);"></i> Creative Arts & Expression</li>
                            <li><i class="fas fa-check-circle" style="color: var(--green);"></i> Building Social Confidence</li>
                        </ul>
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- ========== LEARNING OUTCOMES ========== -->
<section class="outcomes-section section" style="background: var(--gray-bg);">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-blue"><i class="fas fa-graduation-cap"></i> Our Approach</span>
            <h2 class="sec-heading">Core Learning Outcomes</h2>
            <p class="sec-lead">We focus on 5 key pillars of development to ensure a well-rounded foundation.</p>
        </div>
        
        <div class="outcomes-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 30px;">
            <div class="outcome-card" data-aos="zoom-in" style="background: white; padding: 30px; border-radius: 20px; box-shadow: var(--shadow-sm); text-align: center;">
                <div class="oc-icon" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 20px;"><i class="fas fa-language"></i></div>
                <h4 style="margin-bottom: 12px;">Language</h4>
                <p style="font-size: 0.9rem; color: var(--text-light);">Mastering communication & vocabulary.</p>
            </div>
            <div class="outcome-card" data-aos="zoom-in" data-aos-delay="100" style="background: white; padding: 30px; border-radius: 20px; box-shadow: var(--shadow-sm); text-align: center;">
                <div class="oc-icon" style="font-size: 2.5rem; color: var(--green); margin-bottom: 20px;"><i class="fas fa-brain"></i></div>
                <h4 style="margin-bottom: 12px;">Cognitive</h4>
                <p style="font-size: 0.9rem; color: var(--text-light);">Logical thinking & problem solving.</p>
            </div>
            <div class="outcome-card" data-aos="zoom-in" data-aos-delay="200" style="background: white; padding: 30px; border-radius: 20px; box-shadow: var(--shadow-sm); text-align: center;">
                <div class="oc-icon" style="font-size: 2.5rem; color: var(--blue); margin-bottom: 20px;"><i class="fas fa-running"></i></div>
                <h4 style="margin-bottom: 12px;">Physical</h4>
                <p style="font-size: 0.9rem; color: var(--text-light);">Fine & gross motor skill mastery.</p>
            </div>
            <div class="outcome-card" data-aos="zoom-in" data-aos-delay="300" style="background: white; padding: 30px; border-radius: 20px; box-shadow: var(--shadow-sm); text-align: center;">
                <div class="oc-icon" style="font-size: 2.5rem; color: var(--red); margin-bottom: 20px;"><i class="fas fa-heart"></i></div>
                <h4 style="margin-bottom: 12px;">Emotional</h4>
                <p style="font-size: 0.9rem; color: var(--text-light);">Self-awareness & social empathy.</p>
            </div>
            <div class="outcome-card" data-aos="zoom-in" data-aos-delay="400" style="background: white; padding: 30px; border-radius: 20px; box-shadow: var(--shadow-sm); text-align: center;">
                <div class="oc-icon" style="font-size: 2.5rem; color: var(--purple); margin-bottom: 20px;"><i class="fas fa-palette"></i></div>
                <h4 style="margin-bottom: 12px;">Creative</h4>
                <p style="font-size: 0.9rem; color: var(--text-light);">Artistic expression & imagination.</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== FINAL CTA ========== -->
<section class="programs-cta section text-center" style="background: var(--green); color: white;">
    <div class="container" data-aos="zoom-in">
        <h2 style="color: white; font-size: 2.5rem; margin-bottom: 20px;">Unlock Your Child's Potential</h2>
        <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
            Our spots fill up fast! Contact us today to learn more about the curriculum and availability at your preferred branch.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/contact" class="btn btn--white btn--lg">Get Admission Info <i class="fas fa-arrow-right"></i></a>
            <a href="/branches" class="btn btn--outline-white btn--lg">View Branches</a>
        </div>
    </div>
</section>

<style>
    /* Specific styles for sub-page hero */
    .hero--sub {
        min-height: 60vh;
        padding: 120px 0 60px;
        text-align: center;
    }
    
    .hero--sub .hero__badge-top {
        margin-bottom: 24px;
    }

    .hero--sub .hero__heading {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
    }

    .about-text {
        line-height: 1.8;
        color: var(--text-light);
        margin-bottom: 20px;
    }

    .curriculum-list {
        list-style: none;
        padding: 0;
    }

    .curriculum-list li {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        color: var(--text);
    }

    .order-md-1 { order: 1; }
    .order-md-2 { order: 2; }

    @@media (max-width: 767px) {
        .order-md-1, .order-md-2 {
            order: initial !important;
        }
        .program-row {
            margin-bottom: 60px !important;
            text-align: center;
        }
        .sh-underline {
            margin-left: auto;
            margin-right: auto;
        }
        .curriculum-list li {
            justify-content: center;
        }
    }
</style>
