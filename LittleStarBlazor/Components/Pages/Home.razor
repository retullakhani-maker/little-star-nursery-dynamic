@page "/"
@inject LittleStarBlazor.Services.ContentService ContentService
@using LittleStarBlazor.Components.Shared

<PageTitle>Little Star Nursery | Premium Preschool & Learning Center – Surat</PageTitle>

<!-- ========== HERO ========== -->
<section class="hero" id="home">
    <div class="hero__circle hc-1"></div>
    <div class="hero__circle hc-2"></div>
    <div class="hero__circle hc-3"></div>
    <div class="hero__circle hc-4"></div>

    <div class="container hero__inner">
        <div class="hero__content" data-aos="fade-right">
            <div class="hero__badge-top">
                <i class="fas fa-star"></i> Welcome to Little Star Nursery
            </div>
            <h1 class="hero__heading">
                Where Every Child<br>
                <span class="ht-green">Shines</span>
                <span class="ht-yellow">Bright</span>
                <span class="ht-star">⭐</span>
            </h1>
            <p class="hero__sub">
                Premium preschool experience designed for curiosity, growth, and endless smiles. Join our
                vibrant community of little learners!
            </p>
            <div class="hero__actions">
                <a href="#contact" class="btn btn--primary btn--lg"><i class="fas fa-graduation-cap"></i> Enroll Now</a>
                <a href="#about" class="btn btn--outline btn--lg"><i class="fas fa-play-circle"></i> Explore More</a>
            </div>
            <div class="hero__stats">
                <div class="hero__stat">
                    <span class="hero__stat-num" data-target="28000" data-suffix="+">0+</span>
                    <span class="hero__stat-label">Happy Kids</span>
                </div>
                <div class="hero__stat-divider"></div>
                <div class="hero__stat">
                    <span class="hero__stat-num" data-target="40" data-suffix="+">0+</span>
                    <span class="hero__stat-label">Educators</span>
                </div>
                <div class="hero__stat-divider"></div>
                <div class="hero__stat">
                    <span class="hero__stat-num" data-target="4" data-suffix="">0</span>
                    <span class="hero__stat-label">Branches</span>
                </div>
                <div class="hero__stat-divider"></div>
                <div class="hero__stat">
                    <span class="hero__stat-num" data-target="25" data-suffix="+">0+</span>
                    <span class="hero__stat-label">Years</span>
                </div>
            </div>
        </div>

        <div class="hero__visual" data-aos="fade-left">
            <div class="hero__img-wrap">
                <img src="assets/images/nursery_hero_vibrant.png" alt="Kids learning at Little Star Nursery"
                     class="hero__main-img" />
            </div>
            <div class="hv-badge hv-badge-1">
                <i class="fas fa-star" style="color:#FBBF24;"></i>
                <div><strong>Top Rated</strong><span>in Surat</span></div>
            </div>
            <div class="hv-badge hv-badge-2">
                <i class="fas fa-shield-alt" style="color:#22C55E;"></i>
                <div><strong>100% Safe</strong><span>Environment</span></div>
            </div>
        </div>
    </div>

    <div class="hero__wave">
        <svg viewBox="0 0 1440 110" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 60C240 110 480 20 720 60C960 100 1200 20 1440 60V110H0V60Z" fill="#fff9f0" />
        </svg>
    </div>
</section>

<!-- ========== STATS BAR ========== -->
<section class="stats-bar">
    <div class="container stats-grid">
        <div class="stat-item">
            <div class="stat-icon-wrap" style="background:#FEF3C7;color:#D97706;"><i class="fas fa-child"></i></div>
            <div>
                <div class="stat-num" data-target="28000" data-suffix="+">0+</div>
                <div class="stat-label">Happy Students</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon-wrap" style="background:#DCFCE7;color:#16A34A;"><i class="fas fa-chalkboard-teacher"></i></div>
            <div>
                <div class="stat-num" data-target="40" data-suffix="+">0+</div>
                <div class="stat-label">Qualified Teachers</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon-wrap" style="background:#EDE9FE;color:#7C3AED;"><i class="fas fa-school"></i></div>
            <div>
                <div class="stat-num" data-target="4" data-suffix="">0</div>
                <div class="stat-label">Branches in Surat</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon-wrap" style="background:#FEE2E2;color:#DC2626;"><i class="fas fa-award"></i></div>
            <div>
                <div class="stat-num" data-target="25" data-suffix="+">0+</div>
                <div class="stat-label">Years of Excellence</div>
            </div>
        </div>
    </div>
</section>

<!-- ========== BILINGUAL BANNER ========== -->
<section class="bilingual-section">
    <div class="bilingual-stripe-bar">
        <div class="bsb-green"></div>
        <div class="bsb-red"></div>
        <div class="bsb-yellow"></div>
        <div class="bsb-blue"></div>
    </div>
    <div class="container bilingual-inner">
        <div class="bilingual-main">
            <div class="bilingual-text-box">
                <h2>Learning Without Boundaries</h2>
                <p>We offer education in both</p>
                <div class="lang-pills">
                    <span class="lang-pill guj-pill">ગુજરાતી માધ્યમ</span>
                    <span class="lang-amp">&amp;</span>
                    <span class="lang-pill eng-pill">English Medium</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ABOUT PREVIEW ========== -->
<section class="about-section section" id="about">
    <div class="about-dot-pattern"></div>
    <div class="container">
        <div class="about-wrapper">
            <div class="about-img-side" data-aos="fade-right">
                <div class="about-blob-wrap">
                    <img src="assets/images/nursery_hero_vibrant.png" alt="Little Star Learning Environment"
                         class="about-blob-img" />
                </div>
            </div>

            <div class="about-content-side" data-aos="fade-left">
                <span class="sec-badge badge-red"><i class="fas fa-heart"></i> Who We Are</span>
                <h2 class="sec-heading">Kindergarten &amp; Childhood is Our Passion!</h2>
                <div class="sh-underline"></div>
                <p class="about-text">
                    At Little Star Nursery, we provide an environment which helps a child to effectively learn while making learning a matter of sheer joy. Since 2010, we've been nurturing over 28,000 little stars...
                </p>
                <div class="feature-bubbles-grid">
                    <div class="fb-item fbi-red">
                        <div class="fbi-icon"><i class="fas fa-home"></i></div>
                        <span>Homelike Environment</span>
                    </div>
                    <div class="fb-item fbi-blue">
                        <div class="fbi-icon"><i class="fas fa-user-graduate"></i></div>
                        <span>Quality Educators</span>
                    </div>
                </div>
                <div class="mt-4">
                    <a href="about" class="btn btn--primary"><i class="fas fa-info-circle"></i> Read More About Our Story</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== PROGRAMS PREVIEW ========== -->
<section class="programs-section section" id="programs">
    <div class="programs-wave-top">
        <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 40C360 80 720 0 1080 40C1260 60 1350 20 1440 40V0H0V40Z" fill="white" />
        </svg>
    </div>
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-green"><i class="fas fa-book-open"></i> Classes</span>
            <h2 class="sec-heading">Our Programs</h2>
            <p class="sec-lead">From Nursery to Jr. & Sr. Kindergarten, we offer a complete academic foundation for your child.</p>
        </div>

        <div class="programs-grid">
            @foreach (var program in ContentService.GetPrograms().Take(2))
            {
                <ProgramCard Program="program" />
            }
        </div>
        <div class="text-center mt-5" data-aos="fade-up">
            <a href="programs" class="btn btn--secondary btn--lg">View All Programs & Details <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

<!-- ========== TESTIMONIALS ========== -->
<section class="testimonials-section section" id="testimonials">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-purple"><i class="fas fa-heart"></i> Testimonials</span>
            <h2 class="sec-heading">What Parents Say About Us</h2>
            <p class="sec-lead">Hear from the families who trust us with their most precious little ones.</p>
        </div>

        <div class="swiper testimonial-swiper" data-aos="fade-up">
            <div class="swiper-wrapper">
                @foreach (var testimonial in ContentService.GetTestimonials())
                {
                    <TestimonialCard Testimonial="testimonial" />
                }
            </div>
            <div class="swiper-pagination"></div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
        </div>
    </div>
</section>

<!-- ========== BRANCHES PREVIEW ========== -->
<section class="branches-section section" id="branches">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-green"><i class="fas fa-map-marker-alt"></i> Locations</span>
            <h2 class="sec-heading">Our Presence in Surat</h2>
            <p class="sec-lead">4 branches, 1 mission — Premium childhood education at your doorstep.</p>
        </div>
        <div class="branches-grid">
            @foreach (var branch in ContentService.GetBranches().Take(2))
            {
                <div class="branch-card @branch.ColorClass" data-aos="fade-up">
                    <div class="bcard-top">
                        <div class="bcard-pin"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="bcard-title-area">
                            <h3>@branch.Name</h3>
                            <h4 class="guj-text" style="font-family:'Nunito', sans-serif; font-size: 0.9rem; color: var(--text-light); margin-top: -2px;">@branch.NameGujarati</h4>
                        </div>
                    </div>
                    <div class="bcard-info">
                        <p><i class="fas fa-location-dot"></i> @branch.Address</p>
                        <p><i class="fas fa-phone"></i> @branch.Phone</p>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5" data-aos="fade-up">
            <a href="branches" class="btn btn--outline btn--lg">Find All Branches & Maps <i class="fas fa-map-marked-alt"></i></a>
        </div>
    </div>
</section>

<!-- ========== CONTACT PREVIEW ========== -->
<section class="contact-section section" id="contact">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-blue"><i class="fas fa-envelope"></i> Contact</span>
            <h2 class="sec-heading">Have any Questions?</h2>
            <p class="sec-lead">We're happy to help you with the admission process and any other inquiries.</p>
        </div>
        <div class="text-center mt-4" data-aos="fade-up">
            <div class="d-flex flex-wrap justify-content-center gap-4">
                <a href="contact" class="btn btn--primary btn--lg"><i class="fas fa-paper-plane"></i> Send us a Message</a>
                <a href="tel:+919099520954" class="btn btn--outline btn--lg"><i class="fas fa-phone-alt"></i> Call +91 90995 20954</a>
            </div>
        </div>
    </div>
</section>
