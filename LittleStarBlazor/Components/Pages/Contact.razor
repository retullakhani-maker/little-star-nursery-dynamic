@page "/contact"
@inject LittleStarBlazor.Services.ContentService ContentService

<PageTitle>Contact Us | Little Star Nursery</PageTitle>

<section class="gallery-hero">
    <div class="container text-center" data-aos="fade-up">
        <span class="sec-badge badge-blue"><i class="fas fa-paper-plane"></i> Get in Touch</span>
        <h1 class="gallery-hero__title">Contact Us</h1>
        <p class="gallery-hero__sub">
            Have questions? We're here to help. Reach out to us for admissions, inquiries, or to schedule a visit to any of our branches.
        </p>
    </div>
</section>

<section class="contact-page-section section">
    <div class="container">
        <div class="contact-wrapper">
            <div class="contact-info-side" data-aos="fade-right">
                <h3>Contact Information</h3>
                <div class="ci-list">
                    <div class="ci-item" style="--ci-color:#22C55E;">
                        <div class="ci-icon-wrap"><i class="fas fa-phone-alt"></i></div>
                        <div>
                            <h4>Phone</h4>
                            <p>@ContentService.GetBranches().First().Phone</p>
                        </div>
                    </div>
                    <div class="ci-item" style="--ci-color:#3B82F6;">
                        <div class="ci-icon-wrap"><i class="fas fa-envelope"></i></div>
                        <div>
                            <h4>Email</h4>
                            <p>littlestar.eng7@gmail.com</p>
                        </div>
                    </div>
                    <div class="ci-item" style="--ci-color:#EF4444;">
                        <div class="ci-icon-wrap"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <h4>Main Branch</h4>
                            <p>@ContentService.GetBranches().First().Address</p>
                        </div>
                    </div>
                </div>
                <div class="contact-map-embed mt-4">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.839845763266!2d72.8617833!3d21.2183204!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04f7b05133ddb%3A0x34bdeacc8d2f63f0!2sLittle%20Star%20Nursery%20School!5e0!3m2!1sen!2sin!4v1710320000000!5m2!1sen!2sin"
                            width="100%" height="300" style="border:0;border-radius:12px;" allowfullscreen="" loading="lazy"
                            title="Little Star Nursery Surat Location">
                    </iframe>
                </div>
            </div>

            <div class="contact-form-side" data-aos="fade-left">
                <h3>Send Us a Message</h3>
                <form id="contact-form" class="contact-form">
                    <div class="form-row-2">
                        <div class="form-group">
                            <label>Your Name <span>*</span></label>
                            <input type="text" placeholder="e.g. Anita Patel" required />
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="tel" placeholder="+91 98765 43210" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Email Address <span>*</span></label>
                        <input type="email" placeholder="your@email.com" required />
                    </div>
                    <div class="form-group">
                        <label>Program of Interest</label>
                        <select>
                            <option value="">Select a program...</option>
                            @foreach (var program in ContentService.GetPrograms())
                            {
                                <option>@program.Title (@program.AgeRange)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea placeholder="How can we help you?" rows="6"></textarea>
                    </div>
                    <button type="submit" class="btn btn--primary btn--lg w-100">Send Message <i class="fas fa-paper-plane"></i></button>
                </form>
            </div>
        </div>
    </div>
</section>
