@page "/dashboard"
@using LittleStarBlazor.Components.Layout
@inject NavigationManager NavigationManager

<PageTitle>Dashboard | Little Star Nursery</PageTitle>

<div class="dash-layout">
    <aside class="dash-sidebar">
        <div style="padding: 24px; border-bottom: 1px solid rgba(0,0,0,0.05);">
            <img src="assets/images/nursery_hero_vibrant.png" alt="Logo" style="height: 40px;" />
        </div>
        <nav style="padding: 20px 0;">
            <div style="padding: 12px 24px; background: var(--peach); color: var(--primary-d); font-weight: 700;">
                <i class="fas fa-th-large" style="margin-right: 12px;"></i> Overview
            </div>
            <div style="padding: 12px 24px; color: var(--text-light); cursor: pointer;">
                <i class="fas fa-child" style="margin-right: 12px;"></i> Students
            </div>
            <div style="padding: 12px 24px; color: var(--text-light); cursor: pointer;">
                <i class="fas fa-calendar-alt" style="margin-right: 12px;"></i> Attendance
            </div>
            <div style="padding: 12px 24px; color: var(--text-light); cursor: pointer;">
                <i class="fas fa-money-bill-wave" style="margin-right: 12px;"></i> Fees
            </div>
        </nav>
        <div style="margin-top: auto; padding: 20px; border-top: 1px solid rgba(0,0,0,0.05);">
            <button class="btn btn--outline btn--sm w-100" @onclick="Logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </aside>

    <main class="dash-main">
        <header class="dash-header">
            <div>
                <h1 class="dash-title">Welcome, Admin! ✨</h1>
                <p style="color: var(--text-light); font-size: 0.9rem;">Here is what's happening at Little Star today.</p>
            </div>
            <div class="dash-user" style="display: flex; align-items: center; gap: 12px;">
                <div style="text-align: right;">
                    <div style="font-weight: 700; color: var(--text);">Administrator</div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">Main Branch</div>
                </div>
                <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">AD</div>
            </div>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-bottom: 32px;">
            <div class="dash-card">
                <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px;">Total Students</div>
                <div style="font-size: 2rem; font-weight: 700; color: var(--primary);">524</div>
                <div style="color: #22c55e; font-size: 0.8rem; margin-top: 4px;"><i class="fas fa-arrow-up"></i> 12% from last month</div>
            </div>
            <div class="dash-card">
                <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px;">Active Classes</div>
                <div style="font-size: 2rem; font-weight: 700; color: #3b82f6;">18</div>
                <div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 4px;">Across 6 branches</div>
            </div>
            <div class="dash-card">
                <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px;">Upcoming Events</div>
                <div style="font-size: 2rem; font-weight: 700; color: #a855f7;">03</div>
                <div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 4px;">Janmashtami Fest next week</div>
            </div>
        </div>

        <div class="dash-card">
            <h3 style="margin-bottom: 20px;">Recent Admissions</h3>
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 2px solid #f1f5f9;">
                        <th style="padding: 12px 8px; font-size: 0.9rem; color: var(--text-muted);">Student Name</th>
                        <th style="padding: 12px 8px; font-size: 0.9rem; color: var(--text-muted);">Class</th>
                        <th style="padding: 12px 8px; font-size: 0.9rem; color: var(--text-muted);">Branch</th>
                        <th style="padding: 12px 8px; font-size: 0.9rem; color: var(--text-muted);">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-bottom: 1px solid #f1f5f9;">
                        <td style="padding: 16px 8px;">Aryan Patel</td>
                        <td style="padding: 16px 8px;">Nursery</td>
                        <td style="padding: 16px 8px;">Hirabaugh</td>
                        <td style="padding: 16px 8px;"><span style="background: #dcfce7; color: #16a34a; padding: 4px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 700;">Confirmed</span></td>
                    </tr>
                    <tr style="border-bottom: 1px solid #f1f5f9;">
                        <td style="padding: 16px 8px;">Diya Shah</td>
                        <td style="padding: 16px 8px;">Jr. KG</td>
                        <td style="padding: 16px 8px;">Sarthana</td>
                        <td style="padding: 16px 8px;"><span style="background: #fef9c3; color: #ca8a04; padding: 4px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 700;">Pending</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

@code {
    private void Logout()
    {
        NavigationManager.NavigateTo("/login");
    }
}
