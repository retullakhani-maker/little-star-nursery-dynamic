@page "/branches"
@inject LittleStarBlazor.Services.ContentService ContentService

<PageTitle>Our Branches | Little Star Nursery – 4 Locations in Surat</PageTitle>

<!-- ========== BRANCHES HERO ========== -->
<section class="hero hero--sub" id="branches-hero">
    <div class="hero__circle hc-1"></div>
    <div class="hero__circle hc-2"></div>
    
    <div class="container">
        <div class="hero__content text-center" style="max-width: 800px; margin: 0 auto;" data-aos="fade-up">
            <div class="hero__badge-top">
                <i class="fas fa-map-marker-alt"></i> Convenient Locations
            </div>
            <h1 class="hero__heading">
                A Little Star <span class="ht-green">Near</span> Your <span class="ht-yellow">Door</span>
            </h1>
            <p class="hero__sub">
                Explore our 4 vibrant learning centers across Surat. Each branch is a sanctuary of learning, laughter, and high-quality early education.
            </p>
        </div>
    </div>

    <div class="hero__wave">
        <svg viewBox="0 0 1440 110" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 60C240 110 480 20 720 60C960 100 1200 20 1440 60V110H0V60Z" fill="#ffffff" />
        </svg>
    </div>
</section>

<!-- ========== BRANCH LIST ========== -->
<section class="branches-list section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-red"><i class="fas fa-search-location"></i> Find Your Branch</span>
            <h2 class="sec-heading">Our Centers in Surat</h2>
            <p class="sec-lead">Select the branch closest to you to view contact details and directions.</p>
        </div>

        <div class="branches-grid mt-5">
            @foreach (var branch in ContentService.GetBranches())
            {
                <div class="branch-card @branch.ColorClass" data-aos="fade-up" style="transition: transform 0.3s ease; height: 100%;">
                    <div class="bcard-top">
                        <div class="bcard-pin"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="bcard-title-area">
                            <h3 style="font-size: 1.3rem;">@branch.Name</h3>
                            <h4 class="guj-text" style="font-family:'Nunito', sans-serif; font-size: 0.9rem; color: var(--text-light); margin-top: -2px;">@branch.NameGujarati</h4>
                            
                            @if (!string.IsNullOrEmpty(branch.Badge))
                            {
                                <div style="display: flex; gap: 6px; margin-top: 4px;">
                                    <span class="bcard-main-badge">@branch.Badge</span>
                                    <span class="bcard-main-badge" style="background:#fed7d7; color:#c53030;">@branch.BadgeGujarati</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="bcard-info" style="flex-grow: 1;">
                        <p><i class="fas fa-location-dot"></i> @branch.Address</p>
                        <p class="guj-text" style="font-size: 0.85rem; color: var(--text-muted); padding-left: 20px;">@branch.AddressGujarati</p>
                        <p><i class="fas fa-phone"></i> @branch.Phone</p>
                    </div>
                    <div class="bcard-actions">
                        <a href="tel:@branch.Phone.Replace(" ", "")" class="bca-call"><i class="fas fa-phone"></i> Call</a>
                        <a href="@branch.MapLink" class="bca-map" target="_blank"><i class="fas fa-directions"></i> Map</a>
                        <a href="https://wa.me/@(branch.Phone.Replace(" ", "").Replace("+", ""))?text=@Uri.EscapeDataString($"Hi, I am interested in Little Star Nursery ({branch.Name})")" class="bca-wa" target="_blank">
                            <i class="fab fa-whatsapp"></i> Chat
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ========== ALL-BRANCH FACILITIES ========== -->
<section class="facilities-section section" style="background: var(--gray-bg);">
    <div class="container">
        <div class="row align-items-center" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap:60px;">
            <div class="facilities-text" data-aos="fade-right">
                <span class="sec-badge badge-green"><i class="fas fa-shield-alt"></i> Standard Excellence</span>
                <h2 class="sec-heading">Premium Facilities at Every Branch</h2>
                <div class="sh-underline"></div>
                <p class="about-text">Regardless of the location you choose, we ensure your child experiences the same high-tier facilities and safety standards.</p>
                
                <ul class="facilities-list" style="list-style:none; padding:0; margin-top:30px; display: grid; gap: 15px;">
                    <li style="display: flex; align-items: start; gap: 12px;">
                        <div class="f-icon" style="color: var(--green); margin-top: 4px;"><i class="fas fa-video"></i></div>
                        <div>
                            <h5 style="margin-bottom: 2px;">24/7 CCTV Monitoring</h5>
                            <p style="font-size: 0.9rem; color: var(--text-light);">Continuous surveillance for parents' peace of mind.</p>
                        </div>
                    </li>
                    <li style="display: flex; align-items: start; gap: 12px;">
                        <div class="f-icon" style="color: var(--primary); margin-top: 4px;"><i class="fas fa-home"></i></div>
                        <div>
                            <h5 style="margin-bottom: 2px;">Vibrant Classrooms</h5>
                            <p style="font-size: 0.9rem; color: var(--text-light);">Airy, colorful rooms designed for active engagement.</p>
                        </div>
                    </li>
                    <li style="display: flex; align-items: start; gap: 12px;">
                        <div class="f-icon" style="color: var(--blue); margin-top: 4px;"><i class="fas fa-child"></i></div>
                        <div>
                            <h5 style="margin-bottom: 2px;">Safety-First Play Areas</h5>
                            <p style="font-size: 0.9rem; color: var(--text-light);">Indoor and outdoor zones with child-safe flooring.</p>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="facilities-visual" data-aos="fade-left">
                <div style="position: relative;">
                    <img src="assets/images/all_branches.jpeg" alt="Branch Facilities" style="width:100%; border-radius:30px; box-shadow:var(--shadow-lg);" />
                    <div style="position: absolute; bottom: 30px; left: 30px; background: white; padding: 20px; border-radius: 20px; box-shadow: var(--shadow-md);">
                        <div style="display: flex; align-items: center; gap: 10px; color: var(--primary);">
                            <i class="fas fa-check-double fa-2x"></i>
                            <div>
                                <strong style="display: block;">ISO Standard</strong>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">Verified Safety</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ADMISSION CTA ========== -->
<section class="admission-cta section text-center" style="background: var(--primary); color: white;">
    <div class="container" data-aos="zoom-in">
        <h2 style="color: white; font-size: 2.5rem; margin-bottom: 20px;">Still Unsure Which Branch to Pick?</h2>
        <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 40px; max-width: 700px; margin-left: auto; margin-right: auto;">
            Give us a call or visit our Main Branch at Hirabaugh for a comprehensive tour and personalized admission guidance.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="tel:@(ContentService.GetBranches().First().Phone.Replace(" ", ""))" class="btn btn--white btn--lg"><i class="fas fa-phone"></i> Call Main Branch</a>
            <a href="/contact" class="btn btn--outline-white btn--lg">Contact Sales Team</a>
        </div>
    </div>
</section>

<style>
    /* Specific styles for sub-page hero */
    .hero--sub {
        min-height: 60vh;
        padding: 120px 0 60px;
        text-align: center;
    }
    
    .hero--sub .hero__badge-top {
        margin-bottom: 24px;
    }

    .hero--sub .hero__heading {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
    }

    .about-text {
        line-height: 1.8;
        color: var(--text-light);
        margin-bottom: 20px;
    }

    .branch-card:hover {
        transform: translateY(-8px);
    }

    .facilities-list i {
        font-size: 1.2rem;
    }

    @@media (max-width: 767px) {
        .branches-grid {
            grid-template-columns: 1fr !important;
        }
        .sh-underline {
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>
