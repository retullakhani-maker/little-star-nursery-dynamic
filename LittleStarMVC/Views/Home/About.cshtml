@{
    ViewData["Title"] = "About Us";
}

<!-- ========== ABOUT HERO ========== -->
<section class="hero hero--sub" id="about-hero">
    <div class="hero__circle hc-1"></div>
    <div class="hero__circle hc-3"></div>
    
    <div class="container">
        <div class="hero__content text-center" style="max-width: 800px; margin: 0 auto;" data-aos="fade-up">
            <div class="hero__badge-top">
                <i class="fas fa-heart"></i> Nurturing Since 2001
            </div>
            <h1 class="hero__heading">
                Building a <span class="ht-green">Brighter</span> Future,<br>
                One <span class="ht-yellow">Star</span> at a Time
            </h1>
            <p class="hero__sub">
                Discover the heart behind Little Star Nursery. Our journey is defined by a passion for early education and a commitment to creating a second home for your little ones.
            </p>
        </div>
    </div>

    <div class="hero__wave">
        <svg viewBox="0 0 1440 110" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 60C240 110 480 20 720 60C960 100 1200 20 1440 60V110H0V60Z" fill="#ffffff" />
        </svg>
    </div>
</section>

<!-- ========== OUR STORY ========== -->
<section class="about-section section bg-white">
    <div class="container">
        <div class="about-wrapper">
            <div class="about-img-side" data-aos="fade-right">
                <div class="about-blob-wrap">
                    <img src="~/assets/images/nursery_hero_vibrant.png" alt="Little Star Children Learning" class="about-blob-img" />
                </div>
                <div class="about-float-card afc-1">
                    <div class="afc-icon" style="background:#DCFCE7;color:#16A34A;"><i class="fas fa-history"></i></div>
                    <div><strong>25+ Years</strong><span>Legacy</span></div>
                </div>
            </div>

            <div class="about-content-side" data-aos="fade-left">
                <span class="sec-badge badge-red"><i class="fas fa-star"></i> Our Legacy</span>
                <h2 class="sec-heading">Over Two Decades of Love & Learning</h2>
                <div class="sh-underline"></div>
                <p class="about-text">
                    Founded in 2001 with a handful of curious minds, Little Star Nursery has flourished into a beacon of early childhood education in Surat. Our journey began with a simple belief: that every child deserves a safe, vibrant, and joyful place to grow.
                </p>
                <p class="about-text">
                    Today, we proudly serve over <strong>28,000 happy families</strong> across 4 modern branches. While we've grown, our core remains the same—personalized care and a curriculum that inspires wonder.
                </p>
                <div class="about-stats-grid mt-4" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="stat-box" style="background:var(--peach); padding: 20px; border-radius: 16px; text-align: center;">
                        <h3 style="color: var(--primary); font-size: 2rem;">2001</h3>
                        <p style="font-size: 0.9rem; font-weight: 700;">Year Founded</p>
                    </div>
                    <div class="stat-box" style="background:var(--blue-light); padding: 20px; border-radius: 16px; text-align: center;">
                        <h3 style="color: var(--blue); font-size: 2rem;">28k+</h3>
                        <p style="font-size: 0.9rem; font-weight: 700;">Lives Impacted</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== VISION & MISSION ========== -->
<section class="vision-mission section" style="background: #fafafa; position: relative; overflow: hidden;">
    <div class="container">
        <div class="row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;">
            <div class="vision-card" data-aos="fade-up" style="background: white; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-md); border-top: 5px solid var(--green);">
                <div class="icon-circle" style="width: 70px; height: 70px; background: #dcfce7; color: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 24px;">
                    <i class="fas fa-eye"></i>
                </div>
                <h3>Our Vision</h3>
                <p class="about-text">To be the most loved preschool where children transition from curiosity to capability, becoming lifelong learners and compassionate citizens of the world.</p>
            </div>
            <div class="mission-card" data-aos="fade-up" data-aos-delay="100" style="background: white; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-md); border-top: 5px solid var(--primary);">
                <div class="icon-circle" style="width: 70px; height: 70px; background: #ffe5d9; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 24px;">
                    <i class="fas fa-bullseye"></i>
                </div>
                <h3>Our Mission</h3>
                <p class="about-text">Providing a homelike environment that fosters psychological, social, and academic growth through play-based pragmatic learning and personalized care.</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== CORE VALUES ========== -->
<section class="core-values section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-purple"><i class="fas fa-gem"></i> Guiding Principles</span>
            <h2 class="sec-heading">What We Stand For</h2>
            <p class="sec-lead">Our values are the foundation of everything we do at Little Star.</p>
        </div>
        
        <div class="values-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 30px;">
            <div class="value-item" data-aos="zoom-in" style="text-align: center; padding: 30px; transition: transform 0.3s ease;">
                <div class="value-icon" style="font-size: 3rem; color: var(--red); margin-bottom: 20px;"><i class="fas fa-child"></i></div>
                <h4 style="margin-bottom: 12px;">Child-Centric</h4>
                <p style="color: var(--text-light); font-size: 0.95rem;">Every decision we make starts with what is best for the child.</p>
            </div>
            <div class="value-item" data-aos="zoom-in" data-aos-delay="100" style="text-align: center; padding: 30px;">
                <div class="value-icon" style="font-size: 3rem; color: var(--blue); margin-bottom: 20px;"><i class="fas fa-shield-alt"></i></div>
                <h4 style="margin-bottom: 12px;">Purity & Safety</h4>
                <p style="color: var(--text-light); font-size: 0.95rem;">A secure environment where children feel safe to explore and play.</p>
            </div>
            <div class="value-item" data-aos="zoom-in" data-aos-delay="200" style="text-align: center; padding: 30px;">
                <div class="value-icon" style="font-size: 3rem; color: var(--green); margin-bottom: 20px;"><i class="fas fa-leaf"></i></div>
                <h4 style="margin-bottom: 12px;">Holistic Growth</h4>
                <p style="color: var(--text-light); font-size: 0.95rem;">Focusing on mind, heart, and body for all-round development.</p>
            </div>
            <div class="value-item" data-aos="zoom-in" data-aos-delay="300" style="text-align: center; padding: 30px;">
                <div class="value-icon" style="font-size: 3rem; color: var(--primary); margin-bottom: 20px;"><i class="fas fa-laugh-beam"></i></div>
                <h4 style="margin-bottom: 12px;">Joyful Learning</h4>
                <p style="color: var(--text-light); font-size: 0.95rem;">Making education a matter of sheer joy and endless smiles.</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== FOUNDER VISION ========== -->
<section class="founder-section section" style="background: linear-gradient(135deg, var(--blue-light), var(--mint));">
    <div class="container">
        <div class="founder-wrap" style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 60px; align-items: center;">
            <div class="founder-img" data-aos="fade-right">
                <img src="~/assets/images/nursery_hero_vibrant.png" alt="Founder Perspective" style="border-radius: 30px; box-shadow: var(--shadow-lg); transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
            <div class="founder-text" data-aos="fade-left">
                <span class="sec-badge badge-blue"><i class="fas fa-quote-left"></i> From the Founder</span>
                <h2 class="sec-heading">"Nurture the Seed, Watch the Star Shine"</h2>
                <div class="sh-underline"></div>
                <p class="about-text" style="font-style: italic; font-size: 1.1rem; border-left: 3px solid var(--blue); padding-left: 20px;">
                    "Our goal was never just to build a school, but to create a haven where children feel as comfortable as they do at home. We believe in learning by doing, and our greatest reward is seeing a child's eyes light up with understanding."
                </p>
                <div class="founder-info mt-4">
                    <h4 style="margin-bottom: 0;">Little Star Leadership Team</h4>
                    <p style="color: var(--text-muted);">Compassionate Educators</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== WHY CHOOSE US (USPs) ========== -->
<section class="usps section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-yellow"><i class="fas fa-question-circle"></i> Why Us?</span>
            <h2 class="sec-heading">What Makes Us Special</h2>
        </div>
        
        <div class="usp-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;">
            <div class="usp-card" data-aos="fade-up" style="display: flex; gap: 20px;">
                <div class="usp-icon" style="color: var(--primary); font-size: 2rem;"><i class="fas fa-language"></i></div>
                <div>
                    <h4 style="margin-bottom: 8px;">Bilingual Excellence</h4>
                    <p style="color: var(--text-light); font-size: 0.9rem;">Education in both <strong>Gujarati & English Mediums</strong> to provide flexibility for families.</p>
                </div>
            </div>
            <div class="usp-card" data-aos="fade-up" data-aos-delay="100" style="display: flex; gap: 20px;">
                <div class="usp-icon" style="color: var(--green); font-size: 2rem;"><i class="fas fa-puzzle-piece"></i></div>
                <div>
                    <h4 style="margin-bottom: 8px;">Pragmatic Learning</h4>
                    <p style="color: var(--text-light); font-size: 0.9rem;">Activity-based curriculum that focuses on 'Learning by Doing' rather than rote memorization.</p>
                </div>
            </div>
            <div class="usp-card" data-aos="fade-up" data-aos-delay="200" style="display: flex; gap: 20px;">
                <div class="usp-icon" style="color: var(--blue); font-size: 2rem;"><i class="fas fa-users"></i></div>
                <div>
                    <h4 style="margin-bottom: 8px;">Qualified Educators</h4>
                    <p style="color: var(--text-light); font-size: 0.9rem;">Trained professionals who understand child psychology and modern teaching methodologies.</p>
                </div>
            </div>
            <div class="usp-card" data-aos="fade-up" data-aos-delay="300" style="display: flex; gap: 20px;">
                <div class="usp-icon" style="color: var(--red); font-size: 2rem;"><i class="fas fa-map-marked-alt"></i></div>
                <div>
                    <h4 style="margin-bottom: 8px;">4 Strategic Locations</h4>
                    <p style="color: var(--text-light); font-size: 0.9rem;">Conveniently located branches across Surat, making high-quality education accessible.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== CALL TO ACTION ========== -->
<section class="about-cta section text-center" style="background: var(--primary); color: white;">
    <div class="container" data-aos="zoom-in">
        <h2 style="color: white; font-size: 2.5rem; margin-bottom: 20px;">Ready to Start the Journey?</h2>
        <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
            Give your child the gift of a joyful childhood and a strong educational foundation at Little Star Nursery.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/contact" class="btn btn--white btn--lg">Enroll Today <i class="fas fa-arrow-right"></i></a>
            <a href="/branches" class="btn btn--outline-white btn--lg">Find a Branch</a>
        </div>
    </div>
</section>

@section Scripts {
<style>
    /* Specific styles for sub-page hero */
    .hero--sub {
        min-height: 60vh;
        padding: 0px 0 60px;
        text-align: center;
    }
    
    .hero--sub .hero__badge-top {
        margin-bottom: 24px;
    }

    .hero--sub .hero__heading {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
    }

    .about-text {
        line-height: 1.8;
        color: var(--text-light);
        margin-bottom: 20px;
    }

    .value-item:hover {
        transform: translateY(-10px);
    }
    
    /* Founder Section Responsive Fix */
    @@media (max-width: 991px) {
        .founder-wrap {
            grid-template-columns: 1fr !important;
            text-align: center;
        }
        .founder-text {
            order: 2;
        }
        .founder-img {
            order: 1;
            max-width: 400px;
            margin: 0 auto;
        }
    }
</style>
}
