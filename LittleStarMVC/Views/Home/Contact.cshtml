@inject LittleStarMVC.Services.ContentService ContentService
@{
    ViewData["Title"] = "Contact Us";
}

<!-- ========== CONTACT HERO ========== -->
<section class="hero hero--sub" id="contact-hero">
    <div class="hero__circle hc-3"></div>
    <div class="hero__circle hc-4"></div>
    
    <div class="container">
        <div class="hero__content text-center" style="max-width: 800px; margin: 0 auto;" data-aos="fade-up">
            <div class="hero__badge-top">
                <i class="fas fa-paper-plane"></i> Always Here to Help
            </div>
            <h1 class="hero__heading">
                Let's Start a <span class="ht-green">Bright</span> <br>
                <span class="ht-yellow">Conversation</span>
            </h1>
            <p class="hero__sub">
                Whether you have a question about admissions, programs, or just want to say hello, we're just a message away.
            </p>
        </div>
    </div>

    <div class="hero__wave">
        <svg viewBox="0 0 1440 110" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 60C240 110 480 20 720 60C960 100 1200 20 1440 60V110H0V60Z" fill="#ffffff" />
        </svg>
    </div>
</section>

<!-- ========== CONTACT CARDS ========== -->
<section class="contact-info section">
    <div class="container">
        <div class="contact-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px;">
            <div class="c-card" data-aos="fade-up" style="background: white; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-md); text-align: center; border-bottom: 4px solid var(--green);">
                <div class="c-icon" style="width: 70px; height: 70px; background: #dcfce7; color: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 24px;">
                    <i class="fas fa-phone-alt"></i>
                </div>
                <h3>Call Us</h3>
                <p style="color: var(--text-light); margin-bottom: 20px;">Direct line for immediate assistance.</p>
                <a href="tel:@(ContentService.GetBranches().First().Phone.Replace(" ", ""))" style="font-size: 1.2rem; font-weight: 700; color: var(--green);">@ContentService.GetBranches().First().Phone</a>
            </div>
            
            <div class="c-card" data-aos="fade-up" data-aos-delay="100" style="background: white; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-md); text-align: center; border-bottom: 4px solid var(--blue);">
                <div class="c-icon" style="width: 70px; height: 70px; background: #dbeafe; color: #2563eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 24px;">
                    <i class="fas fa-envelope"></i>
                </div>
                <h3>Email Us</h3>
                <p style="color: var(--text-light); margin-bottom: 20px;">Send us your detailed inquiries.</p>
                <a href="mailto:littlestar.eng7@gmail.com" style="font-size: 1.1rem; font-weight: 700; color: var(--blue);">littlestar.eng7@gmail.com</a>
            </div>
            
            <div class="c-card" data-aos="fade-up" data-aos-delay="200" style="background: white; padding: 40px; border-radius: 24px; box-shadow: var(--shadow-md); text-align: center; border-bottom: 4px solid var(--primary);">
                <div class="c-icon" style="width: 70px; height: 70px; background: #ffe5d9; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 24px;">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <h3>Main Office</h3>
                <p style="color: var(--text-light); margin-bottom: 20px;">Visit our central administrative hub.</p>
                <p style="font-weight: 600;">Hirabaugh, Surat</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== CONTACT FORM & MAP ========== -->
<section class="contact-main section" style="background: var(--gray-bg);">
    <div class="container">
        <div class="contact-wrapper" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 60px; align-items: start;">
            <div class="contact-form-side" data-aos="fade-right" style="background: white; padding: 50px; border-radius: 30px; box-shadow: var(--shadow-lg);">
                <span class="sec-badge badge-purple"><i class="fas fa-envelope-open-text"></i> Message Box</span>
                <h2 class="sec-heading" style="margin-bottom: 30px;">Send a Direct Message</h2>
                
                <form id="contact-form" class="contact-form" style="display: grid; gap: 20px;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.9rem;">Parent's Name <span>*</span></label>
                            <input type="text" placeholder="Full Name" required style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; background: #f9f9f9;" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.9rem;">Child's Age</label>
                            <input type="text" placeholder="e.g. 3 Years" style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; background: #f9f9f9;" />
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.9rem;">Phone Number <span>*</span></label>
                            <input type="tel" placeholder="+91 ..." required style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; background: #f9f9f9;" />
                        </div>
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.9rem;">Branch Interest</label>
                            <select style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; background: #f9f9f9;">
                                <option>Select a branch...</option>
                                @foreach(var b in ContentService.GetBranches()) {
                                    <option>@b.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 0.9rem;">Your Message</label>
                        <textarea placeholder="How can we help your child shine?" rows="5" style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; background: #f9f9f9;"></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn--primary btn--lg" style="width: 100%; justify-content: center;">
                        Submit Inquiry <i class="fas fa-paper-plane"></i>
                    </button>
                </form>
            </div>
            
            <div class="contact-map-side" data-aos="fade-left">
                <div style="position: sticky; top: 120px;">
                    <h2 class="sec-heading">Visit Main Branch</h2>
                    <p class="about-text">Drop by our administrative hub for a friendly chat and a tour of our facilities.</p>
                    
                    <div class="map-container" style="border-radius: 30px; overflow: hidden; box-shadow: var(--shadow-lg); line-height: 0;">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.839845763266!2d72.8617833!3d21.2183204!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04f7b05133ddb%3A0x34bdeacc8d2f63f0!2sLittle%20Star%20Nursery%20School!5e0!3m2!1sen!2sin!4v1710320000000!5m2!1sen!2sin"
                                width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" title="Location on Map">
                        </iframe>
                    </div>
                    
                    <div class="map-info mt-4" style="background: white; padding: 25px; border-radius: 20px; box-shadow: var(--shadow-sm); display: flex; gap: 20px; align-items: start;">
                        <i class="fas fa-clock fa-2x" style="color: var(--primary);"></i>
                        <div>
                            <h5 style="margin-bottom: 4px;">Visiting Hours</h5>
                            <p style="font-size: 0.9rem; color: var(--text-light);">Mon - Sat: 8:00 AM - 6:00 PM<br>Sun: Closed</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== FAQ PREVIEW ========== -->
<section class="faq-preview section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="sec-badge badge-yellow"><i class="fas fa-question-circle"></i> FAQ</span>
            <h2 class="sec-heading">Common Questions</h2>
        </div>
        
        <div class="faq-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
            <div class="faq-item" data-aos="fade-up" style="background: var(--white); padding: 30px; border-radius: 20px; border-left: 5px solid var(--primary);">
                <h4 style="margin-bottom: 10px;">What is the minimum age for admission?</h4>
                <p style="font-size: 0.95rem; color: var(--text-light);">We welcome children starting from 2 years old in our Bal Vatika program.</p>
            </div>
            <div class="faq-item" data-aos="fade-up" data-aos-delay="100" style="background: var(--white); padding: 30px; border-radius: 20px; border-left: 5px solid var(--blue);">
                <h4 style="margin-bottom: 10px;">Do you provide transportation?</h4>
                <p style="font-size: 0.95rem; color: var(--text-light);">Yes, we offer safe bus services for students across most neighborhoods in Surat.</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<style>
    /* Specific styles for sub-page hero */
    .hero--sub {
        min-height: 60vh;
        padding: 0px 0 60px;
        text-align: center;
    }
    
    .hero--sub .hero__badge-top {
        margin-bottom: 24px;
    }

    .hero--sub .hero__heading {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
    }

    .about-text {
        line-height: 1.8;
        color: var(--text-light);
        margin-bottom: 20px;
    }

    .c-card:hover {
        transform: translateY(-8px);
    }

    @@media (max-width: 991px) {
        .contact-wrapper {
            grid-template-columns: 1fr !important;
        }
        .contact-map-side {
            order: 2;
        }
        .contact-form-side {
            order: 1;
            padding: 30px !important;
        }
    }

    @@media (max-width: 575px) {
        .faq-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>
}
